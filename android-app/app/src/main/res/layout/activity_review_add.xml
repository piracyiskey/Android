<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/gray">

    <!-- Header (Your provided layout) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="@color/white">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_back_black"
            android:scaleType="fitCenter"
            android:padding="8dp"
            android:contentDescription="Back" />

        <TextView
            android:id="@+id/title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Viết Đánh giá"
            android:textSize="20sp"
            android:textColor="@android:color/black"
            android:textStyle="bold"
            android:gravity="center" />

        <View
            android:layout_width="40dp"
            android:layout_height="40dp" />
    </LinearLayout>

    <!-- Body -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp"
        android:background="@color/gray"
        android:layout_marginTop="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bạn nghĩ gì về sản phẩm này?"
            android:gravity="center"
            android:textStyle="bold"
            android:textSize="24sp"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Hãy đưa ra đánh giá của bạn bằng cách bấm vào các ngôi sao ở bên dưới"
            android:textSize="14sp"
            android:textColor="@color/black"
            android:layout_marginTop="10dp" />

        <!-- Star rating -->
        <LinearLayout
            android:id="@+id/starContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical">

            <ImageView android:id="@+id/star1" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_star_empty" app:tint="@color/yellow"/>
            <ImageView android:id="@+id/star2" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_star_empty" app:tint="@color/yellow"/>
            <ImageView android:id="@+id/star3" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_star_empty" app:tint="@color/yellow"/>
            <ImageView android:id="@+id/star4" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_star_empty" app:tint="@color/yellow"/>
            <ImageView android:id="@+id/star5" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_star_empty" app:tint="@color/yellow"/>
        </LinearLayout>

        <!-- Review input -->
        <EditText
            android:id="@+id/edtReview"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/otp_box"
            android:hint="Cho chúng tôi biết về trải nghiệm của bạn"
            android:padding="12dp"
            android:textColor="@android:color/black"
            android:textSize="14sp"
            android:gravity="top|start"
            android:inputType="textMultiLine" />


        <!-- Submit Button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSubmit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Đánh giá"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:layout_marginTop="20dp"
            android:background="@drawable/btn_gradient"
            android:textSize="20sp"
            android:paddingVertical="12dp" />
    </LinearLayout>
</LinearLayout>
