<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray">

    <!-- Back + Title -->
    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="@color/white">

        <!-- Actual Back Arrow Button -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_back_black"
            android:scaleType="fitCenter"
            android:padding="8dp"
            android:contentDescription="Back" />

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <!-- Welcome text -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Khôi phục mật khẩu"
            android:textSize="20sp"
            android:textColor="#000000"
            android:textStyle="bold"
            android:layout_gravity="center" />

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <!-- Dummy right-aligned view to balance the back button -->
        <View
            android:layout_width="40dp"
            android:layout_height="40dp" />
    </LinearLayout>

    <!-- Main content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:layout_marginTop="100dp"
        android:gravity="top|center_horizontal">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Xác thực Email"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="8dp" />

        <!-- Description -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vui lòng nhập mã Otp đã gửi đến Email"
            android:textSize="14sp"
            android:textColor="#888888"
            android:textAlignment="center"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Verification code input -->
        <LinearLayout
            android:id="@+id/otpLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="8dp">

            <!-- Repeat this EditText 6 times for OTP digits -->
            <EditText
                android:id="@+id/otp1"
                style="@style/OtpBoxStyle" />

            <EditText
                android:id="@+id/otp2"
                style="@style/OtpBoxStyle" />

            <EditText
                android:id="@+id/otp3"
                style="@style/OtpBoxStyle" />

            <EditText
                android:id="@+id/otp4"
                style="@style/OtpBoxStyle" />

            <EditText
                android:id="@+id/otp5"
                style="@style/OtpBoxStyle" />

            <EditText
                android:id="@+id/otp6"
                style="@style/OtpBoxStyle" />
        </LinearLayout>




        <!-- Submit Button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tiếp tục"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:layout_marginTop="20dp"
            android:background="@drawable/btn_gradient"
            android:textSize="16sp"
            android:paddingVertical="12dp" />

        <TextView
            android:id="@+id/txtAgain"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:text="Không nhận được mã? Gửi lại"
            android:textColor="#666666"
            android:textSize="14sp" />

    </LinearLayout>

</FrameLayout>