<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    tools:context=".Activity.ProductDetailsActivity">

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Product Image with Back Button -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="400dp"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/imgProduct"
                    android:layout_width="match_parent"
                    android:background="@android:color/white"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop" />

                <!-- Back button -->
                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_back"
                    android:scaleType="fitCenter"
                    android:padding="8dp"
                    app:tint="@color/primary"
                    android:contentDescription="Back" />

            </FrameLayout>

            <!-- Info section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Price + Heart Icon -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/txtPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="15.000 VND"
                        android:textColor="@color/secondary"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/imgFavorite"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_heart" />
                </RelativeLayout>

                <!-- Name -->
                <TextView
                    android:id="@+id/txtName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Chanh hữu cơ"
                    android:textSize="21sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp" />

                <!-- Per -->
                <TextView
                    android:id="@+id/txtPer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1 kg"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:layout_marginTop="4dp" />

                <!-- Rating -->
                <include
                    layout="@layout/view_star_rating"
                    android:id="@+id/ratingLayout"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="8dp" />


                <!-- Description -->
                <TextView
                    android:id="@+id/txtDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mô tả sản phẩm..."
                    android:textSize="14sp"
                    android:textColor="#444444"
                    android:layout_marginTop="12dp"
                    android:lineSpacingExtra="4dp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Quantity and Cart Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="#F7F7F7">

        <!-- Quantity label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Số lượng"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <!-- Quantity Control -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:background="@drawable/quantity_bg"
            android:gravity="center"
            android:layout_marginBottom="12dp">

            <!-- Minus Button -->
            <TextView
                android:id="@+id/btnMinus"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="−"
                android:gravity="center"
                android:textSize="20sp"
                android:textColor="@color/secondary"
                android:background="@android:color/transparent" />

            <!-- Quantity Text -->
            <TextView
                android:id="@+id/tvQuantity"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="3"
                android:textSize="18sp"
                android:textColor="@android:color/black"
                android:background="@drawable/bg_quantity_center" />


            <!-- Plus Button -->
            <TextView
                android:id="@+id/btnPlus"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="+"
                android:gravity="center"
                android:textSize="20sp"
                android:textColor="@color/secondary"
                android:background="@android:color/transparent" />
        </LinearLayout>


        <!-- Add to Cart Button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnAddToCart"
            android:paddingHorizontal="16dp"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/btn_gradient"
            android:text="       Thêm vào giỏ hàng"
            android:textColor="@android:color/white"
            android:drawableEnd="@drawable/ic_cart1"
            android:drawablePadding="8dp"
            android:gravity="center"
            android:textSize="16sp" />
    </LinearLayout>
</LinearLayout>
